# SSH credentials for OpenWRT router, Iran client, Dubai server, and Sweden server.
# Copy this to .env and fill in the values. Do not commit .env to version control.

# Router credentials
SSH_HOST_1=192.168.10.1
SSH_USER_1=root
SSH_PASSWORD_1=your_router_password

# Iran client server credentials
SSH_HOST_2=192.168.10.159
SSH_USER_2=root
SSH_PASSWORD_2=your_iran_host_password

# Dubai server credentials (key-based auth)
SSH_HOST_3=139.185.53.54
SSH_USER_3=ubuntu
SSH_PRIVATE_KEY_3="-----BEGIN RSA PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"

# Sweden server credentials (password-based auth)
SSH_HOST_4=82.70.50.192
SSH_USER_4=root
SSH_PASSWORD_4=your_sweden_server_password
